---
import { getCollection } from 'astro:content';
import Landing from '../../layouts/Landing.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Landing
  title="Blog — dbdeployer"
  description="News, releases, and technical deep-dives from the dbdeployer team."
>
  <div class="blog-index-wrapper">
    <div class="blog-index-container">
      <header class="blog-index-header">
        <h1 class="blog-index-title">Blog</h1>
        <p class="blog-index-subtitle">News, releases, and technical deep-dives from the dbdeployer team.</p>
      </header>

      {posts.length === 0 ? (
        <p class="blog-empty">No posts yet. Check back soon.</p>
      ) : (
        <div class="blog-post-list">
          {posts.map((post) => (
            <BlogPostCard
              title={post.data.title}
              date={post.data.date}
              author={post.data.author}
              description={post.data.description}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </div>
  </div>
</Landing>

<style>
  .blog-index-wrapper {
    padding: 4rem 1.5rem 6rem;
  }

  .blog-index-container {
    max-width: 820px;
    margin: 0 auto;
  }

  .blog-index-header {
    margin-bottom: 3rem;
  }

  .blog-index-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .blog-index-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  .blog-post-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .blog-empty {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }
</style>
